<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Kigo</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>3</string>
	<!-- Kigo uses only standard, exempt encryption (HTTPS for the remote manifest).
	     Declaring this skips the per-build "Missing Compliance" prompt in TestFlight. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIAppFonts</key>
	<array>
		<string>ShipporiMincho-Regular.ttf</string>
		<string>ShipporiMincho-Medium.ttf</string>
		<string>ShipporiMincho-SemiBold.ttf</string>
		<string>ShipporiMincho-Bold.ttf</string>
		<string>ShipporiMincho-ExtraBold.ttf</string>
		<string>ZenKakuGothicNew-Light.ttf</string>
		<string>ZenKakuGothicNew-Regular.ttf</string>
		<string>ZenKakuGothicNew-Medium.ttf</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- iPhone-only, portrait-only (see TARGETED_DEVICE_FAMILY=1 in project.yml).
	     A single portrait orientation is valid for iPhone-only apps, so no
	     iPad-multitasking opt-out is needed. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
