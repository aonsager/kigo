{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(perl:*)",
      "Bash(python3:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(test:*)",
      "Bash(true)",
      "Bash(xcodegen:*)",
      "Bash(xcodebuild:*)",
      "Bash(xcrun:*)",
      "Bash(xcode-select:*)",
      "Bash(swift:*)",
      "Bash(brew install xcodegen)",
      "Bash(plutil:*)"
    ],
    "deny": []
  },
  "sandbox": {
    "excludedCommands": [
      "gh *",
      "git fetch *",
      "git push *",
      "git pull *",
      "git clone *",
      "git ls-remote *"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com"
      ]
    }
  }
}
